# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/threatchain

# Redis
REDIS_URL=redis://localhost:6379/0

# Threat Intel APIs
VIRUSTOTAL_API_KEY=your_key
ABUSEIPDB_API_KEY=your_key
SHODAN_API_KEY=your_key
OTX_API_KEY=your_key
URLSCAN_API_KEY=your_key
NVD_API_KEY=your_key
HYBRID_ANALYSIS_API_KEY=your_key
GREYNOISE_API_KEY=your_key
PULSEDIVE_API_KEY=your_key
SECURITYTRAILS_API_KEY=your_key
HIBP_API_KEY=your_key

# LLMs
OPENAI_API_KEY=your_key
ANTHROPIC_API_KEY=your_key
XAI_API_KEY=your_key
GEMINI_API_KEY=your_key
DEEPSEEK_API_KEY=your_key
GROQ_API_KEY=your_key

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# API Key auth (leave empty to disable)
API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
INVESTIGATION_TIMEOUT_SECONDS=120
CACHE_TTL_HOURS=24
