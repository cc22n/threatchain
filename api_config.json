    "phishtank":       {"base_url": "https://checkurl.phishtank.com/checkurl",                        "api_key_env": null,                       "rate_limit_per_day": 10000, "rate_limit_per_minute": 60},
    "securitytrails":  {"base_url": "https://api.securitytrails.com/v1",                              "api_key_env": "SECURITYTRAILS_API_KEY",   "rate_limit_per_day": 50,    "rate_limit_per_minute": 2},
    "exploitdb":       {"base_url": "https://www.exploit-db.com/search",                              "api_key_env": null,                       "rate_limit_per_day": 1000,  "rate_limit_per_minute": 10},
    "threatcrowd":     {"base_url": "https://www.threatcrowd.org/searchApi/v2",                       "api_key_env": null,                       "rate_limit_per_day": 10000, "rate_limit_per_minute": 60},
