    "hybrid_analysis": {"base_url": "https://www.hybrid-analysis.com/api/v2",                         "api_key_env": "HYBRID_ANALYSIS_API_KEY",  "rate_limit_per_day": 200,   "rate_limit_per_minute": 5},
    "greynoise":       {"base_url": "https://api.greynoise.io/v3",                                    "api_key_env": "GREYNOISE_API_KEY",        "rate_limit_per_day": 50,    "rate_limit_per_minute": 10},
    "pulsedive":       {"base_url": "https://pulsedive.com/api",                                      "api_key_env": "PULSEDIVE_API_KEY",        "rate_limit_per_day": 30,    "rate_limit_per_minute": 5},
