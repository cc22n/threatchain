    "urlscan":         {"base_url": "https://urlscan.io/api/v1",                                      "api_key_env": "URLSCAN_API_KEY",          "rate_limit_per_day": 50,    "rate_limit_per_minute": 5},
    "nvd":             {"base_url": "https://services.nvd.nist.gov/rest/json/cves/2.0",               "api_key_env": "NVD_API_KEY",              "rate_limit_per_day": 2000,  "rate_limit_per_minute": 5},
