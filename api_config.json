{
  "apis": {
    "virustotal":      {"base_url": "https://www.virustotal.com/api/v3",                              "api_key_env": "VIRUSTOTAL_API_KEY",       "rate_limit_per_day": 500,   "rate_limit_per_minute": 4},
    "abuseipdb":       {"base_url": "https://api.abuseipdb.com/api/v2",                               "api_key_env": "ABUSEIPDB_API_KEY",        "rate_limit_per_day": 1000,  "rate_limit_per_minute": 60},
